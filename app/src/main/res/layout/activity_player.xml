<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="16dp"
    android:paddingEnd="24dp"
    android:paddingBottom="32dp"
    android:id="@+id/main">

    <!-- Back Button -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_circle_dark"
        android:contentDescription="Back"
        android:padding="9dp"
        android:src="@drawable/ic_arrow_back"
        android:clickable="true"/>

    <!-- Story Poster -->
    <ImageView
        android:id="@+id/imgCover"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/bg_story_cover_placeholder"
        android:contentDescription="Story poster"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:src="@drawable/ic_placeholder_cover" />

    <!-- Story Name -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Kuch Toh Hai"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Episode Name -->
    <!--    <TextView-->
    <!--        android:id="@+id/tvPlayerEpisode"-->
    <!--        android:layout_width="match_parent"-->
    <!--        android:layout_height="wrap_content"-->
    <!--        android:layout_marginBottom="20dp"-->
    <!--        android:ellipsize="end"-->
    <!--        android:maxLines="1"-->
    <!--        android:text="Episode 24"-->
    <!--        android:textColor="#888888"-->
    <!--        android:textSize="13sp" />-->

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#FF6B35"
        android:thumbTint="#FF6B35" />

    <!-- Time Row -->
    <!--    <LinearLayout-->
    <!--        android:layout_width="match_parent"-->
    <!--        android:layout_height="wrap_content"-->
    <!--        android:orientation="horizontal"-->
    <!--        android:layout_marginBottom="28dp">-->

    <!--        <TextView-->
    <!--            android:id="@+id/tvTime"-->
    <!--            android:layout_width="wrap_content"-->
    <!--            android:layout_height="wrap_content"-->
    <!--            android:text="00:00"-->
    <!--            android:textColor="#888888"-->
    <!--            android:textSize="12sp" />-->

    <!--        <View-->
    <!--            android:layout_width="0dp"-->
    <!--            android:layout_height="0dp"-->
    <!--            android:layout_weight="1" />-->

    <!--        <TextView-->
    <!--            android:id="@+id/tvTotalTime"-->
    <!--            android:layout_width="wrap_content"-->
    <!--            android:layout_height="wrap_content"-->
    <!--            android:text="00:00"-->
    <!--            android:textColor="#888888"-->
    <!--            android:textSize="12sp" />-->

    <!--    </LinearLayout>-->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:text="00:00 / 00:00"
        android:textColor="#BBBBBB" />

    <!-- Controls: Rewind | Play/Pause | Forward -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Rewind 10s -->
        <ImageView
            android:id="@+id/btnBackward"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="Rewind 10 seconds"
            android:padding="8dp"
            android:src="@drawable/ic_replay_10"
            android:clickable="true"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Play / Pause -->
        <ImageView
            android:id="@+id/btnPlayPause"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_orange"
            android:contentDescription="Play / Pause"
            android:padding="16dp"
            android:src="@drawable/ic_pause"
            android:clickable="true"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Forward 10s -->
        <ImageView
            android:id="@+id/btnForward"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="Forward 10 seconds"
            android:padding="8dp"
            android:src="@drawable/ic_forward_10"
            android:clickable="true"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Speed Control -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_speed_panel"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Speed"
            android:textColor="#AAAAAA"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="7">

            <TextView
                android:id="@+id/tvSpeed05"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_speed_chip"
                android:gravity="center"
                android:text="0.5x"
                android:textColor="#888888"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvSpeed075"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_speed_chip"
                android:gravity="center"
                android:text="0.75x"
                android:textColor="#888888"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvSpeed1"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_speed_chip_selected"
                android:gravity="center"
                android:text="1x"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSpeed125"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_speed_chip"
                android:gravity="center"
                android:text="1.25x"
                android:textColor="#888888"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvSpeed15"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_speed_chip"
                android:gravity="center"
                android:text="1.5x"
                android:textColor="#888888"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvSpeed175"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_speed_chip"
                android:gravity="center"
                android:text="1.75x"
                android:textColor="#888888"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvSpeed2"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/bg_speed_chip"
                android:gravity="center"
                android:text="2x"
                android:textColor="#888888"
                android:textSize="10sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>