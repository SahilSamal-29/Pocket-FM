<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:id="@+id/main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cover Image + Back Button Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="360dp">

            <!-- Full Cover Image -->
            <ImageView
                android:id="@+id/imgBanner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_story_cover_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="Story Cover" />

            <!-- Bottom fade so title reads clearly -->
            <View
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_gradient_bottom" />

            <!-- Back Button (top left) -->
            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_circle_dark"
                android:padding="9dp"
                android:src="@drawable/ic_arrow_back"
                android:clickable="true"
                android:contentDescription="Back" />

            <!-- Title on top of gradient -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Kuch Toh Hai"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Body Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <!-- Genre + Episode Count -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvDetailGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_genre_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="Drama"
                    android:textColor="#FF6B35"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDetailEpisodeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="80 Episodes"
                    android:textColor="#888888"
                    android:textSize="13sp" />

            </LinearLayout>


            <!-- Buttons Row: Play Now + Add to Library -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp"
                android:weightSum="2">

                <!-- Add to Library Button -->
                <LinearLayout
                    android:id="@+id/btnAddToLibrary"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_outline_button"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivLibraryIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/outline_add_box_24"
                        android:contentDescription="Add to Library" />

                    <TextView
                        android:id="@+id/tvLibraryBtnLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add to Library"
                        android:textColor="#FF6B35"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Play Now Button -->
                <LinearLayout
                    android:id="@+id/btnPlay"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_primary_button"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_play"
                        android:contentDescription="Play" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Play Now"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- About Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="About this story"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="5dp"
                android:text="A gripping tale of love, secrets, and betrayal set in the heart of Mumbai. Follow Priya and Arjun as they navigate family drama, hidden pasts, and unexpected emotions that change their lives forever."
                android:textColor="#AAAAAA"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>