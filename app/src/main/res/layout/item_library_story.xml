<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:layout_marginBottom="12dp"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <!-- Cover Thumbnail -->
    <ImageView
        android:id="@+id/ivLibraryCover"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_story_cover_placeholder"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_placeholder_cover"
        android:contentDescription="Cover" />

    <!-- Text Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvLibraryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Story Title"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLibraryMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Drama · Ep 12 of 80"
            android:textColor="#888888"
            android:textSize="12sp" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/pbLibraryProgress"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progress="40"
            android:progressTint="#FF6B35"
            android:progressBackgroundTint="#333333" />

    </LinearLayout>

    <!-- Play Button -->
    <ImageView
        android:id="@+id/ivLibraryPlay"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_circle_orange"
        android:padding="9dp"
        android:src="@drawable/ic_play"
        android:contentDescription="Play" />

</LinearLayout>
